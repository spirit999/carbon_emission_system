<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bjfu.carbon.mapper.AuditLogMapper">

    <resultMap id="BaseResultMap" type="com.bjfu.carbon.domain.AuditLog">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="ip" property="ip"/>
        <result column="url" property="url"/>
        <result column="method" property="method"/>
        <result column="params" property="params"/>
        <result column="status_code" property="statusCode"/>
        <result column="response_time" property="responseTime"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 优化的分页查询：使用子查询先获取ID，避免全表排序 -->
    <select id="selectPageOptimized" resultMap="BaseResultMap">
        SELECT 
            al.id, al.user_id, al.username, al.ip, al.url, al.method, 
            al.params, al.status_code, al.response_time, al.create_time
        FROM audit_log al
        INNER JOIN (
            SELECT id
            FROM audit_log
            <where>
                <if test="startDate != null">
                    AND create_time >= #{startDate}
                </if>
                <if test="endDate != null">
                    AND create_time &lt;= #{endDate}
                </if>
                <if test="userId != null">
                    AND user_id = #{userId}
                </if>
                <if test="username != null and username != ''">
                    AND username LIKE CONCAT('%', #{username}, '%')
                </if>
                <if test="url != null and url != ''">
                    AND url LIKE CONCAT('%', #{url}, '%')
                </if>
            </where>
            ORDER BY create_time DESC
            LIMIT #{offset}, #{size}
        ) AS ids ON al.id = ids.id
        ORDER BY al.create_time DESC
    </select>

    <!-- 优化的总数查询：只统计符合条件的记录数 -->
    <select id="selectCountOptimized" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM audit_log
        <where>
            <if test="startDate != null">
                AND create_time >= #{startDate}
            </if>
            <if test="endDate != null">
                AND create_time &lt;= #{endDate}
            </if>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="url != null and url != ''">
                AND url LIKE CONCAT('%', #{url}, '%')
            </if>
        </where>
    </select>

</mapper>
